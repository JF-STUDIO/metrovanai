{
  "name": "metrovanai-web-rebuild",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.28.1",
  "scripts": {
    "dev": "pnpm --parallel --filter metrovan-ai-server --filter metrovan-ai-client dev",
    "dev:client": "pnpm --filter metrovan-ai-client dev",
    "dev:server": "pnpm --filter metrovan-ai-server dev",
    "build": "pnpm --filter metrovan-ai-server build && pnpm --filter metrovan-ai-client build",
    "maintain:check": "node ./scripts/maintenance-check.mjs",
    "test:regression": "node ./scripts/regression-checks.mjs",
    "test:critical": "pnpm test:regression && node ./scripts/critical-flow-contracts.mjs",
    "test:e2e": "playwright test",
    "smoke:runpod-worker": "node ./scripts/smoke-runpod-worker.mjs",
    "smoke:auth-session": "node ./scripts/smoke-auth-session.mjs",
    "smoke:r2-direct-upload": "node ./scripts/smoke-r2-direct-upload.mjs",
    "smoke:auth-billing": "node ./scripts/smoke-auth-billing.mjs",
    "check:commercial": "node ./scripts/check-commercial-readiness.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1"
  }
}
